<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description || G.title }}">
  <title>{{ title || G.title }}</title>
  <!-- Prevent flash of wrong theme before CSS loads -->
  <script>(function(){var t=localStorage.getItem("theme")||(window.matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light");document.documentElement.dataset.theme=t})();</script>
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='white'/><text x='4' y='22' font-size='14'>សិទ្ធិ</text></svg>">
  <script src="/main.js" defer></script>
</head>
<body>
<a href="#main" class="skip-link">Skip to content</a>
<header>
  <a href="/" class="site-title">{{ G.title }}</a>
  <button onclick="switchTheme()" id="theme-switcher" aria-label="Switch to dark mode">🌙 Dark</button>
</header>
<main id="main">
{{ content }}

{{ function renderSection(pages = []) }}
  {{ if pages.length == 0 }}
    <p>Nothing to see here yet.</p>
  {{ /if }}
  <ul class="post-list">
  {{ for page of pages.sort((a, b) => {
      if (b.pinned || false) return 1;
      if (a.pinned || false) return -1;
      return new Date(b.date) - new Date(a.date);
    }) }}
    <li>
      <a href="{{ page.url }}">
        <span>{{ page.title || page.basename }}</span>
        <span class="post-date">{{ page.date?.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) || "—" }}</span>
      </a>
    </li>
  {{ /for }}
  </ul>
{{ /function }}

<section class="posts-section">
  <h2>Posts</h2>
  {{ renderSection(search.pages("type='post'")) }}
</section>
</main>

<footer>
  <span>{{ G.index_footer }}</span>
  <nav aria-label="Social links" class="footer-links">
    <a href="{{ G.mail }}">Mail</a>
    <a href="{{ G.github }}" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="{{ G.x }}" target="_blank" rel="noopener noreferrer">X</a>
  </nav>
</footer>
</body>
</html>
